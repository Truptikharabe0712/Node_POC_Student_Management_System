PORT=5000
STORAGE_MODE=postgres

# PostgreSQL settings for STORAGE_MODE=postgres
# Option 1: full connection string
# DATABASE_URL=postgres://postgres:root@localhost:5432/student_db

# Option 2: individual fields
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=student_db
# DB_USER=postgres
# DB_PASSWORD=root

# If you use the JSON storage mode, leave the PostgreSQL values commented out.
